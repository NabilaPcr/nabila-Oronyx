<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    tools:context=".Home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <View
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/sida_dark_green"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_marginStart="24dp"
            android:text="Halo, Selamat Datang!"
            android:fontFamily="@font/redrose"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SISTEM INFORMASI KEBENCANAAN"
            android:fontFamily="@font/redrose"
            android:textSize="14sp"
            android:textColor="#B9F6CA"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="@id/tvWelcome"/>

        <LinearLayout
            android:id="@+id/menuLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-60dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/headerBg">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRumus"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_margin="8dp"
                android:layout_weight="1"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnRumus"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KALKULATOR"
                        android:fontFamily="@font/redrose"
                        android:textColor="@color/sida_dark_green"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCustom1"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_margin="8dp"
                android:layout_weight="1"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnProfil"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROFIL"
                        android:fontFamily="@font/redrose"
                        android:textColor="@color/sida_dark_green"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCustom2"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/sida_dark_green"
            app:layout_constraintTop_toBottomOf="@+id/menuLayout">
            <Button
                android:id="@+id/btnList"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="TO DO LIST KEGIATAN"
                android:fontFamily="@font/redrose"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWebView"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="12dp"
            android:text="Web SiDa"
            android:fontFamily="@font/redrose"
            android:textAllCaps="false"
            app:backgroundTint="@color/sida_green"
            app:cornerRadius="20dp"
            app:elevation="6dp"
            app:layout_constraintEnd_toStartOf="@+id/btnLogout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardCustom2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="24dp"
            android:layout_marginStart="12dp"
            android:text="Logout"
            android:fontFamily="@font/redrose"
            android:textAllCaps="false"
            app:backgroundTint="@color/sida_red"
            app:cornerRadius="20dp"
            app:elevation="6dp"
            app:layout_constraintBottom_toBottomOf="@+id/btnWebView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btnWebView"
            app:layout_constraintTop_toTopOf="@+id/btnWebView" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>