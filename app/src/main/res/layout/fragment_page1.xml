<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/sida_bg_light"> <ImageView
    android:id="@+id/imgIllustration"
    android:layout_width="200dp"
    android:layout_height="200dp"
    android:src="@drawable/p1"
    android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat Datang di SiDa"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/sida_dark_green" android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solusi digital cerdas untuk kemudahan pemantauan dan pelaporan data secara real-time."
        android:textSize="16sp"
        android:textColor="@color/sida_dark_green"
        android:gravity="center"
        android:textAlignment="center"/>

</LinearLayout>